#: src/FLTube_View.cxx:426
msgid ""
"Please wait until the application data is loaded. This may take a little "
"while..."
msgstr ""
"Espere a que se carguen los datos de la aplicación. Esto podría tardar un "
"poco..."

#: src/userdata_manager.cxx:38
#, c-format
msgid ""
"There was an error when loading data from %s. The file will be rewritted, "
"and previous copied to a backup file %s.\n"
msgstr ""
"Hubo un error al cargar datos desde %s. El archivo será sobreescrito, y "
"previamente copiado al archivo de backup %s.\n"

#: src/userdata_manager.cxx:43
#, c-format
msgid "User Data was loaded correctly from %s .\n"
msgstr "Datos del usuario cargados correctamente desde %s.\n"

#: src/userdata_manager.cxx:56
#, c-format
msgid ""
"The user data file at %s doesn't exists. Will be created at program exit...\n"
msgstr ""
"El archivo de datos de usuario %s no existe. Se creará al cerrar el "
"programa...\n"

#: src/userdata_manager.cxx:64
#, c-format
msgid "Specified version at first line (%s)is not valid. Abort processing...\n"
msgstr ""
"La versión especificada en la primer línea (%s) no es válida. Abortando "
"procesamiento...\n"

#: src/userdata_manager.cxx:72
#, c-format
msgid ""
"Error while parsing version number at '%s' userdata file. Abort "
"processing...\n"
msgstr ""
"Error al analizar el número de versión en el archivo de datos de usuario "
"'%s'. Abortando procesamiento...\n"

#: src/userdata_manager.cxx:103
#, c-format
msgid "ABORT VIDEO PROCESSING. Video field size = %lu \n"
msgstr ""
"ABORTANDO PROCESAMIENTO DEL VIDEO. Cantidad de campos en el video = %lu \n"

#: src/userdata_manager.cxx:131
#, c-format
msgid ""
"List '%s' is duplicated at userdata file. Avoiding to add duplication...\n"
msgstr ""
"La lista '%s' se encuentra duplicada en el archivo de datos de usuario. Se "
"evita agregar la lista duplicada...\n"

#: src/userdata_manager.cxx:146
#, c-format
msgid "Video not found: %s.\n"
msgstr "Video no encontrado: %s.\n"

#: src/userdata_manager.cxx:151
#, c-format
msgid "- List '%s' (Count of videos: %d).\n"
msgstr "- Lista '%s' (Cantidad de videos: %d).\n"

#: src/userdata_manager.cxx:164
#, c-format
msgid "Userdata was saved succesfully at '%s' file.\n"
msgstr ""
"Los datos del usuario fueron guardados exitósamente en el archivo '%s'.\n"

#: src/userdata_manager.cxx:167
#, c-format
msgid ""
"Userdata file cannot be saved at '%s'!!! Check if you have write permission "
"on directory...\n"
msgstr ""
"¡¡¡El archivo de datos de usuario no puede ser guardado en '%s'!!! Verifica "
"si tienes permiso de escritura en ese directorio...\n"

#: src/userdata_manager.cxx:251
msgid "Video is a null pointer... Cannot proceed.\n"
msgstr "Video es un puntero nulo... No se puede proceder.\n"

#: src/userdata_manager.cxx:299
msgid ""
"Cannot add video because one of the parameters, video or listName, is "
"empty...\n"
msgstr ""
"No se puede agregar el video porque uno de los siguientes parámetros, video "
"o nombre de lista, está vacío...\n"

#: src/userdata_manager.cxx:304
#, c-format
msgid "Cannot add video to a non-existent list '%s'.\n"
msgstr "No se puede agregar un video en la lista inexistente '%s'.\n"

#: src/userdata_manager.cxx:316
msgid ""
"Cannot remove video because one of the parameters, listName or id, is "
"empty...\n"
msgstr ""
"No se puede eliminar el video porque uno de los siguientes parámetros, id o "
"nombre de lista, está vacío...\n"

#: src/userdata_manager.cxx:321
#, c-format
msgid "Cannot add remove from a non-existent list '%s'.\n"
msgstr "No se puede eliminar un video en la lista inexistente '%s'.\n"

#: src/userdata_manager.cxx:390
msgid "Error: Cannot add a null video.\n"
msgstr "Error: no se puede agregar un video nulo.\n"

#: src/ytdlp_helper.cxx:191
msgid ""
"The default stream command doesn't work. Fallback to the alternative method "
"to get final video URL."
msgstr ""
"El comando de transmisión predeterminado no funciona. Recurra al método "
"alternativo para obtener la URL final del video."

#: src/ytdlp_helper.cxx:196
msgid ""
"Cannot obtain URL for specified video, and alternative stream method is "
"disabled."
msgstr ""
"No se puede obtener la URL del video especificado y el método de transmisión "
"alternativo está deshabilitado."

